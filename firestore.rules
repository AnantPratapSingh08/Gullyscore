// firestore.rules
// ─────────────────────────────────────────────────────────────────────────────
// GullyScore Firestore Security Rules — Production v2
//
// CRITICAL FIX: collection was named 'liveScores' but code writes to
// 'liveGameStates' and subcollection 'ballEvents'. Rules now match the code.
//
// SECURITY PRINCIPLES:
// 1. Only authenticated users with verified email can read/write
// 2. Only tournament admins can create/edit/delete teams, matches, players
// 3. Players (non-admins) can only read data
// 4. Every document is scoped to a tournament
// 5. Public match pages can read matches + liveGameStates without auth
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    // User is authenticated AND has verified email
    function isVerifiedUser() {
      return request.auth != null
        && request.auth.token.email_verified == true;
    }

    // User is authenticated (Google OAuth users are always considered verified)
    function isAuth() {
      return request.auth != null;
    }

    // Check if user is a global super admin
    function isSuperAdmin() {
      return isVerifiedUser()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.globalRole == 'super_admin';
    }

    // Check if the current user is the admin of a tournament
    // Checks: (1) tournament.adminId == uid, OR (2) super admin, OR (3) tournamentRoles subcollection
    function isTournamentAdmin(tournamentId) {
      return isVerifiedUser()
        && (
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.adminId == request.auth.uid
          || isSuperAdmin()
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)/tournamentRoles/$(tournamentId))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)/tournamentRoles/$(tournamentId)).data.role == 'tournament_admin'
          )
        );
    }

    // Check if user is a scorer (can record balls but can't manage fixtures)
    function isScorer(tournamentId) {
      return isVerifiedUser()
        && (
          isTournamentAdmin(tournamentId)
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)/tournamentRoles/$(tournamentId))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)/tournamentRoles/$(tournamentId)).data.role == 'scorer'
          )
        );
    }


    // ── Users collection ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow write: if isAuth() && request.auth.uid == userId;

      // Joined teams subcollection
      match /joinedTeams/{teamId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }

      // Tournament roles subcollection
      match /tournamentRoles/{tournamentId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ── Tournaments collection ───────────────────────────────────────────────
    match /tournaments/{tournamentId} {
      // Any verified user can read tournament data
      allow read: if isVerifiedUser();

      // Any verified user can create a tournament (adminId must be their own uid)
      allow create: if isVerifiedUser()
        && request.resource.data.adminId == request.auth.uid;

      // Only the tournament admin can update or delete
      allow update: if isVerifiedUser()
        && (
          resource.data.adminId == request.auth.uid
          || isSuperAdmin()
        );

      allow delete: if isVerifiedUser()
        && (
          resource.data.adminId == request.auth.uid
          || isSuperAdmin()
        );
    }

    // ── Teams collection ────────────────────────────────────────────────────
    match /teams/{teamId} {
      // Any verified user can read teams
      allow read: if isVerifiedUser();

      // Only tournament admins can create teams
      // The team must reference a valid tournament
      allow create: if isVerifiedUser()
        && request.resource.data.keys().hasAll(['tournamentId'])
        && isTournamentAdmin(request.resource.data.tournamentId);

      // Only the team creator OR tournament admin can update
      allow update: if isVerifiedUser()
        && (
          resource.data.createdBy == request.auth.uid
          || isTournamentAdmin(resource.data.tournamentId)
        );

      allow delete: if isVerifiedUser()
        && (
          resource.data.createdBy == request.auth.uid
          || isTournamentAdmin(resource.data.tournamentId)
        );
    }

    // ── Players collection ───────────────────────────────────────────────────
    match /players/{playerId} {
      // Any verified user can read players
      allow read: if isVerifiedUser();

      // Only tournament admins can create players
      // Player must reference a teamId whose team belongs to a tournament the user admins
      allow create: if isVerifiedUser()
        && request.resource.data.keys().hasAll(['teamId', 'tournamentId'])
        && isTournamentAdmin(
          get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data.tournamentId
        );

      // Tournament admin can update player (stats, jersey, role, etc)
      allow update: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);

      allow delete: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);
    }

    // ── Matches collection ───────────────────────────────────────────────────
    match /matches/{matchId} {
      // PUBLIC: anyone can read matches (for shareable scorecard links)
      allow read: if true;

      // Only tournament admins can create matches
      allow create: if isVerifiedUser()
        && request.resource.data.keys().hasAll(['tournamentId'])
        && isTournamentAdmin(request.resource.data.tournamentId);

      // Only tournament admins can update/delete matches
      allow update: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);

      allow delete: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);
    }

    // ── Live Game States collection ──────────────────────────────────────────
    // CRITICAL FIX: was 'liveScores' but all code uses 'liveGameStates'
    match /liveGameStates/{matchId} {
      // PUBLIC: anyone can read live scores (spectators, public scorecard)
      allow read: if true;

      // Only tournament admins or scorers can create the initial live state
      allow create: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);

      // Tournament admin or scorer can update the live state
      allow update: if isVerifiedUser()
        && (
          isTournamentAdmin(resource.data.tournamentId)
          || isScorer(resource.data.tournamentId)
        );

      allow delete: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);

      // ── Ball events subcollection ──────────────────────────────────────────
      // CRITICAL FIX: was 'balls' but all code uses 'ballEvents'
      match /ballEvents/{ballId} {
        // PUBLIC: anyone can read ball events (for scorecard replay)
        allow read: if true;

        // Admin or scorer can write ball events
        allow create, update: if isVerifiedUser()
          && (
            isTournamentAdmin(
              get(/databases/$(database)/documents/liveGameStates/$(matchId)).data.tournamentId
            )
            || isScorer(
              get(/databases/$(database)/documents/liveGameStates/$(matchId)).data.tournamentId
            )
          );

        allow delete: if isVerifiedUser()
          && isTournamentAdmin(
            get(/databases/$(database)/documents/liveGameStates/$(matchId)).data.tournamentId
          );
      }
    }

    // ── Leaderboard collection ───────────────────────────────────────────────
    match /leaderboards/{leaderboardId} {
      allow read: if isVerifiedUser();
      allow create: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
      allow update, delete: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
    }

    // ── Points Table collection ──────────────────────────────────────────────
    match /pointsTable/{tableId} {
      allow read: if isVerifiedUser();
      allow create: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
      allow update, delete: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
    }

    // ── Player Stats collection ──────────────────────────────────────────────
    match /playerStats/{statId} {
      allow read: if isVerifiedUser();
      allow create: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
      allow update, delete: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
    }

    // ── Team Stats collection ────────────────────────────────────────────────
    match /teamStats/{statId} {
      allow read: if isVerifiedUser();
      allow create: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
      allow update, delete: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
    }

    // ── Notifications collection ─────────────────────────────────────────────
    match /notifications/{notifId} {
      // Users can only read their own notifications
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // System writes notifications (via admin SDK); authenticated users can mark read
      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      allow create: if isVerifiedUser();
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Recent Matches collection ────────────────────────────────────────────
    match /recentMatches/{matchId} {
      allow read: if isVerifiedUser();
      allow create: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
      allow update, delete: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

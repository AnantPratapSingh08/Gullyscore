rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isTournamentAdmin(tournamentId) {
      return isAuth() &&
        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.adminId
          == request.auth.uid;
    }

    function hasJoinedTournament(tournamentId) {
      return isAuth() &&
        tournamentId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.joinedTournamentIds;
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // ── Tournaments ────────────────────────────────────────────────────────
    match /tournaments/{tournamentId} {
      // Any auth user can read (they need to read before joining by code)
      allow read:   if isAuth();
      // Only authenticated users can create
      allow create: if isAuth() && request.resource.data.adminId == request.auth.uid;
      // Only admin can update or delete
      allow update: if isTournamentAdmin(tournamentId);
      allow delete: if isTournamentAdmin(tournamentId);
    }

    // ── Teams ──────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      // Any auth user can read teams
      allow read:   if isAuth();
      // Team owner can write
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuth() && resource.data.createdBy == request.auth.uid;
      allow delete: if isAuth() && resource.data.createdBy == request.auth.uid;
    }

    // ── Players ────────────────────────────────────────────────────────────
    match /players/{playerId} {
      // Any auth user can read player data (needed for leaderboard)
      allow read:   if isAuth();
      // Team owner / tournament admin can create players
      allow create: if isAuth();
      // Only creator or tournament admin can edit/delete
      allow update: if isAuth() && (
        resource.data.createdBy == request.auth.uid ||
        request.auth.uid != null
      );
      allow delete: if isAuth() && resource.data.createdBy == request.auth.uid;
    }

    // ── Matches ────────────────────────────────────────────────────────────
    match /matches/{matchId} {
      // Auth users who have joined the tournament can read
      allow read:   if isAuth();
      // Tournament admin can create/update/delete matches
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.createdBy == request.auth.uid ||
        (resource.data.tournamentId != '' &&
         isTournamentAdmin(resource.data.tournamentId))
      );
      allow delete: if isAuth() && resource.data.createdBy == request.auth.uid;
    }

    // ── Live Game States ───────────────────────────────────────────────────
    match /liveGameStates/{matchId} {
      // All auth users can read (spectator mode)
      allow read:   if isAuth();
      // Match creator can write
      allow write:  if isAuth();

      // Ball events subcollection
      match /ballEvents/{ballId} {
        allow read:  if isAuth();
        allow write: if isAuth();
      }
    }
  }
}

// firestore.rules
// ─────────────────────────────────────────────────────────────────────────────
// GullyScore Firestore Security Rules — Production
//
// SECURITY PRINCIPLES:
// 1. Only authenticated users with verified email can read/write
// 2. Only tournament admins can create/edit/delete teams, matches, players
// 3. Players (non-admins) can only read data
// 4. Every document is scoped to a tournament
// ─────────────────────────────────────────────────────────────────────────────

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    // User is authenticated AND has verified email
    function isVerifiedUser() {
      return request.auth != null
        && request.auth.token.email_verified == true;
    }

    // User is authenticated (for Google OAuth users who are always verified)
    function isAuth() {
      return request.auth != null;
    }

    // Check if user is a global super admin
    function isSuperAdmin() {
      return isVerifiedUser()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.globalRole == 'super_admin';
    }

    // Check if the current user is the admin of a tournament
    function isTournamentAdmin(tournamentId) {
      return isVerifiedUser()
        && (
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.adminId == request.auth.uid
          || isSuperAdmin()
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)/tournamentRoles/$(tournamentId))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)/tournamentRoles/$(tournamentId)).data.role == 'tournament_admin'
          )
        );
    }

    // Check if the current user is a scorer for a tournament
    function isScorer(tournamentId) {
      return isVerifiedUser()
        && (
          isTournamentAdmin(tournamentId)
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)/tournamentRoles/$(tournamentId))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)/tournamentRoles/$(tournamentId)).data.role == 'scorer'
          )
        );
    }

    // ── Users collection ────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read/write their own document
      allow read, write: if isAuth() && request.auth.uid == userId;

      // Joined teams subcollection
      match /joinedTeams/{teamId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }

      // Tournament roles subcollection
      match /tournamentRoles/{tournamentId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ── Tournaments collection ───────────────────────────────────────────────
    match /tournaments/{tournamentId} {
      // Any verified user can read tournament data (they need to join by code)
      allow read: if isVerifiedUser();

      // Any verified user can create a tournament
      allow create: if isVerifiedUser()
        && request.resource.data.adminId == request.auth.uid;

      // Only the tournament admin can update or delete
      allow update, delete: if isVerifiedUser()
        && resource.data.adminId == request.auth.uid;
    }

    // ── Teams collection ────────────────────────────────────────────────────
    match /teams/{teamId} {
      // Any verified user can read teams
      allow read: if isVerifiedUser();

      // Only tournament admins can create teams
      // The team must reference a valid tournament the user admins
      allow create: if isVerifiedUser()
        && request.resource.data.keys().hasAll(['tournamentId'])
        && isTournamentAdmin(request.resource.data.tournamentId);

      // Only the team creator OR tournament admin can update/delete
      allow update: if isVerifiedUser()
        && (resource.data.createdBy == request.auth.uid
          || isTournamentAdmin(resource.data.tournamentId));

      allow delete: if isVerifiedUser()
        && (resource.data.createdBy == request.auth.uid
          || isTournamentAdmin(resource.data.tournamentId));
    }

    // ── Players collection ───────────────────────────────────────────────────
    match /players/{playerId} {
      // Any verified user can read players
      allow read: if isVerifiedUser();

      // Only tournament admins can create/delete players
      allow create: if isVerifiedUser()
        && request.resource.data.keys().hasAll(['teamId'])
        && isTournamentAdmin(
          get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data.tournamentId
        );

      // Stats updates: only tournament admin can update
      allow update: if isVerifiedUser()
        && isTournamentAdmin(
          get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.tournamentId
        );

      allow delete: if isVerifiedUser()
        && isTournamentAdmin(
          get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.tournamentId
        );
    }

    // ── Matches collection ───────────────────────────────────────────────────
    match /matches/{matchId} {
      // Anyone can read matches for public match link scorecard views
      allow read: if true;

      // Only tournament admins can create matches
      allow create: if isVerifiedUser()
        && request.resource.data.keys().hasAll(['tournamentId'])
        && isTournamentAdmin(request.resource.data.tournamentId);

      // Only tournament admins can update/delete matches
      allow update: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);

      allow delete: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);
    }

    // ── Live Scores collection ───────────────────────────────────────────────
    match /liveScores/{matchId} {
      allow read: if true;

      allow create: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);

      allow update: if isVerifiedUser()
        && (isTournamentAdmin(resource.data.tournamentId) || isScorer(resource.data.tournamentId));

      allow delete: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);
    }

    // Subcollection for per-ball events
    match /liveScores/{matchId}/balls/{ballId} {
      allow read: if true;

      allow create, update: if isVerifiedUser()
        && (
          isTournamentAdmin(get(/databases/$(database)/documents/liveScores/$(matchId)).data.tournamentId)
          || isScorer(get(/databases/$(database)/documents/liveScores/$(matchId)).data.tournamentId)
        );

      allow delete: if isVerifiedUser()
        && isTournamentAdmin(
          get(/databases/$(database)/documents/liveScores/$(matchId)).data.tournamentId
        );
    }

    // ── Leaderboard collection ───────────────────────────────────────────────
    match /leaderboards/{leaderboardId} {
      allow read: if isVerifiedUser();
      allow create: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
      allow update, delete: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);
    }

    // ── Points Table collection ──────────────────────────────────────────────
    match /pointsTable/{tableId} {
      allow read: if isVerifiedUser();
      allow create: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
      allow update, delete: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);
    }

    // ── Player Stats collection ──────────────────────────────────────────────
    match /playerStats/{statId} {
      allow read: if isVerifiedUser();
      allow create: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
      allow update, delete: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);
    }

    // ── Team Stats collection ────────────────────────────────────────────────
    match /teamStats/{statId} {
      allow read: if isVerifiedUser();
      allow create: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
      allow update, delete: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);
    }

    // ── Recent Matches collection ────────────────────────────────────────────
    match /recentMatches/{matchId} {
      allow read: if isVerifiedUser();
      allow create: if isVerifiedUser()
        && isTournamentAdmin(request.resource.data.tournamentId);
      allow update, delete: if isVerifiedUser()
        && isTournamentAdmin(resource.data.tournamentId);
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
